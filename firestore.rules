rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User-specific data (Projects)
    match /users/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Community Templates (Public read, Authenticated write)
    match /templates/{templateId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
    }
    
    // Shared Mods (Snapshots)
    match /shared_mods/{modId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    
    // Changelog (Admin only write, Public read)
    match /changelog/{entry} {
      allow read: if true;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }
  }
}